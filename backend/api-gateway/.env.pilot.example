# FinKlik — production pilot template
# Copy to .env.pilot.local (gitignored) or inject via hosting secrets.
# Generate secrets: python -c "import secrets; print(secrets.token_hex(32))"

DATABASE_URL=postgresql+asyncpg://finklik:PILOT_DB_PASSWORD@localhost:5433/finklik_pilot
REDIS_URL=redis://localhost:6380/0

JWT_SECRET_KEY=REPLACE_JWT_SECRET
JWT_REFRESH_SECRET_KEY=REPLACE_JWT_REFRESH
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Required for 🟢 pilot-check (non-empty; use real provider in prod)
EMAIL_API_KEY=REPLACE_EMAIL_API_KEY

MOCK_BANK_URL=http://localhost:8011
ONEC_MOCK_URL=http://localhost:8002

SUBMISSION_PORTAL_MODE=mock
DEBUG=false
DISABLE_RATE_LIMIT=0

CORS_ORIGINS=http://localhost:4173,http://localhost:5173,https://your-frontend.example.com
